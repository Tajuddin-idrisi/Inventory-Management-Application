{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/InventoryManagement.API/bin/Debug/net9.0/InventoryManagement.API.dll",
      "cwd": "${workspaceFolder}/InventoryManagement.API",
      "args": [],
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:5041;http://localhost:5040"
      },
      "stopAtEntry": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Run Web",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/InventoryManagement.Web/bin/Debug/net9.0/InventoryManagement.Web.dll",
      "cwd": "${workspaceFolder}/InventoryManagement.Web",
      "args": [],
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:5042;http://localhost:5043"
      },
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Now listening on: (https?://\\S+)",
        "uriFormat": "%s/Login",
        "action": "openExternally"
      }
    }
  ],
  "compounds": [
    {
      "name": "Run API + Web",
      "configurations": ["Run API", "Run Web"]
    }
  ]
}
